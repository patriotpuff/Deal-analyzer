/* CSV import */
function parseCsvRows(text){const rows=[];let field="",row=[],q=false;for(let i=0;i<text.length;i++){const c=text[i];if(q){if(c==='"'){if(text[i+1]==='"'){field+='"';i++;}else q=false;}else field+=c;}else if(c==='"')q=true;else if(c===','){row.push(field);field="";}else if(c==='\n'||c==='\r'){if(c==='\r'&&text[i+1]==='\n')i++;row.push(field);rows.push(row);row=[];field="";}else field+=c;}if(field.length>0||row.length>0){row.push(field);rows.push(row);}return rows.filter(r=>r.some(c=>c.trim()!==""));}
function parseMoney(raw){if(!raw)return undefined;const c=raw.replace(/[^0-9.\-]/g,"");if(c===""||c==="-"||c===".")return undefined;const n=Number(c);return isFinite(n)?n:undefined;}
function parseAddr(raw){const primary=raw.split("&")[0].trim();const parts=primary.split(",").map(p=>p.trim()).filter(Boolean);if(!parts.length)return{};const out={address:parts[0]};if(parts.length>=2)out.city=parts[1];const tail=parts[parts.length-1],m=tail.match(/\b([A-Za-z]{2})\b\s*(\d{5})?/);if(m&&parts.length>=3){out.state=m[1].toUpperCase();if(m[2])out.zip=m[2];}else if(parts.length===2){const m2=parts[1].match(/\b([A-Za-z]{2})\b\s*(\d{5})?/);if(m2){out.state=m2[1].toUpperCase();if(m2[2])out.zip=m2[2];out.city=undefined;}}return out;}
const ALIASES={"client name":"client",client:"client",name:"client",address:"address","property address":"address",email:"email",phone:"phone","year 2 buyback":"buyback","2 year buyback":"buyback",buyback:"buyback","buyback price":"buyback","capital deployed":"capital",basis:"capital","cost basis":"capital","funding amount":"capital","option fee":"option","monthly rent":"rent",rent:"rent","lease term":"term","lease term months":"term"};
function applyTemplate(t,buyback){if(buyback==null)return t;if(t.capital_deployed==null)t.capital_deployed=Math.round(buyback*TEMPLATE.fundPct/100);const basis=t.capital_deployed;if(t.option_fee==null)t.option_fee=Math.round(basis*TEMPLATE.optionPct/100);if(t.total_fees==null)t.total_fees=Math.round(basis*TEMPLATE.feesPct/100);if(t.lease_term_months==null)t.lease_term_months=TEMPLATE.termMonths;return t;}
function parseDealsCsv(text){const rows=parseCsvRows(text);if(rows.length<2)return{deals:[],errors:["Need a header row and at least one data row."]};const header=rows[0].map(h=>ALIASES[h.trim().toLowerCase()]);if(!header.includes("address"))return{deals:[],errors:['No "Address" column found.']};const deals=[];for(let r=1;r<rows.length;r++){const cells=rows[r];const get=k=>{const i=header.indexOf(k);return i>=0?(cells[i]||"").trim():undefined;};const addr=get("address");if(!addr)continue;const loc=parseAddr(addr);const bb=parseMoney(get("buyback"))??null;const terms=applyTemplate({capital_deployed:parseMoney(get("capital"))??null,buyback_price_y2:bb,option_fee:parseMoney(get("option"))??null,monthly_rent:parseMoney(get("rent"))??null,lease_term_months:parseMoney(get("term"))??null},bb);deals.push({client:get("client"),address:loc.address,city:loc.city,state:loc.state,zip:loc.zip,terms,property:{market_value:null},facts:{},enrich:{},note:"Imported via CSV — facts/value fill from RealEstateAPI in production."});}return{deals,errors:deals.length?[]:["No data rows with an address found."]};}

/* ============================================================================ LENDER MATCHING */
const STATUS_LABEL={pipeline:"In pipeline",purchasing:"Being purchased",purchased:"Purchased",passed:"Passed"};
function loanAmountFor(d){const a=d.analysis||{};return a.cost_basis!=null?a.cost_basis:costBasis(d.terms||{}).v;}
function dscrFor(d){const rent=(d.enrich&&d.enrich.rentEstimate)||(d.terms&&d.terms.monthly_rent);const loan=loanAmountFor(d);if(!rent||!loan)return null;const pay=loan*0.09/12;return pay>0?rent/pay:null;}
/* Evaluate every lender against a deal. A blank requirement is skipped (= no requirement). */
function matchLenders(d){
  const a=d.analysis||{},loan=loanAmountFor(d),mv=a.market_value;
  const ltv=(loan!=null&&mv)?Math.round(loan/mv*100):null, dscr=dscrFor(d);
  const age=(d.facts&&d.facts.yearBuilt)?CURRENT_YEAR-d.facts.yearBuilt:null;
  const reserves=(d.borrower&&d.borrower.liquidAssets)||0, payment=loan?loan*0.09/12:null;
  const qualified=[],blocked=[];
  LENDERS.forEach(L=>{const f=[];
    if(L.states&&L.states.length&&d.state&&!L.states.includes(d.state)) f.push(`Doesn't lend in ${d.state}`);
    if(L.loanMin!=null&&loan!=null&&loan<L.loanMin) f.push(`Loan ${money(loan)} < min ${money(L.loanMin)}`);
    if(L.loanMax!=null&&loan!=null&&loan>L.loanMax) f.push(`Loan ${money(loan)} > max ${money(L.loanMax)}`);
    if(L.maxLTV!=null&&ltv!=null&&ltv>L.maxLTV) f.push(`LTV ${ltv}% > ${L.maxLTV}%`);
    if(L.minDSCR!=null&&dscr!=null&&dscr<L.minDSCR) f.push(`DSCR ${dscr.toFixed(2)} < ${L.minDSCR}`);
    if(L.minReserveMonths!=null&&payment!=null&&reserves<L.minReserveMonths*payment) f.push(`Reserves < ${L.minReserveMonths} mo`);
    if(L.maxAge!=null&&age!=null&&age>L.maxAge) f.push(`Built ${d.facts.yearBuilt} — older than ${L.maxAge} yrs`);
    (f.length?blocked:qualified).push({L,fails:f});
  });
  return {qualified,blocked,ctx:{loan,ltv,dscr,age}};
}
function lenderMatchBlock(d){
  const m=matchLenders(d),c=m.ctx;
  const row=(x,ok)=>`<div style="display:flex;justify-content:space-between;gap:12px;align-items:center;padding:8px 11px;border-radius:9px;margin-bottom:6px;background:${ok?'#eafaf1':'#fdeef0'};border:1px solid ${ok?'#bfe6d2':'#f6cdd5'};"><div><b>${x.L.name}</b>${x.L.notes?` <span class="note">— ${x.L.notes}</span>`:""}</div>${ok?'<span style="color:#177a52;font-weight:700;white-space:nowrap;">✓ Qualifies</span>':`<span style="color:#b3122f;font-size:12px;text-align:right;">${x.fails.join(" · ")}</span>`}</div>`;
  return `<div class="section"><div class="secttitle">🏦 Lender fit — ${m.qualified.length} of ${LENDERS.length} can fund this deal</div><div class="card">
    <div class="metrics" style="margin-bottom:12px;">
      <div class="metric"><div class="k">Loan needed</div><div class="v">${money(c.loan)}</div></div>
      <div class="metric"><div class="k">LTV</div><div class="v">${c.ltv!=null?Math.round(c.ltv)+'%':'—'}</div></div>
      <div class="metric"><div class="k">Est. DSCR</div><div class="v">${c.dscr!=null?c.dscr.toFixed(2):'—'}</div><div class="h">rent ÷ IO @9%</div></div>
      <div class="metric"><div class="k">Property age</div><div class="v">${c.age!=null?c.age+' yrs':'—'}</div></div>
    </div>
    ${m.qualified.map(x=>row(x,true)).join("")}
    ${m.blocked.map(x=>row(x,false)).join("")}
    <div class="note" style="margin-top:8px;">Requirements come from the <b>Lenders</b> tab — a blank field there means that lender has no requirement on that parameter.</div>
  </div></div>`;
}

/* Buyer/situation/property synopsis — homeowner name bolded. */
function generateSynopsis(d){
  const b=d.borrower||{},f=d.facts||{},a=d.analysis||{};
  const name=d.client||"The homeowner", loc=[d.city,d.state].filter(Boolean).join(", ");
  const intent=(b.intent&&b.intent!=="Not stated")?b.intent:null;
  const emp=(b.employment&&b.employment!=="Not provided")?b.employment:null;
  const inc=b.monthlyIncome?money(b.monthlyIncome)+"/mo":null;
  const struct=[f.beds!=null?f.beds+" bd":"",f.baths!=null?f.baths+" ba":"",f.sqft?f.sqft.toLocaleString()+" sqft":""].filter(Boolean).join(" / ");
  const built=f.yearBuilt?`built ${f.yearBuilt}`:"", typ=f.type||"home";
  let s=`<b>${name}</b>${loc?` of ${loc}`:""} is entering a sale-leaseback`;
  if(intent) s+=` — looking to ${intent.charAt(0).toLowerCase()+intent.slice(1)}`;
  s+=`. `;
  if(emp||inc||b.creditScore){ s+=`They report ${[emp,inc].filter(Boolean).join(", ")||"limited financials"}${b.creditScore?`, credit ~${b.creditScore}`:""}. `; }
  s+=`The property is a ${[built,typ].filter(Boolean).join(" ")}${struct?` (${struct})`:""}${loc?` in ${loc}`:""}, valued ~${money(a.market_value)} against a Year-2 buyback of ${money(a.buyback_price)}. `;
  if(d.note) s+=d.note;
  return s;
}

