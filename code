        <label class="field" style="grid-column:1/3;"><span>Locations (state codes, comma-separated — blank = nationwide)</span><input type="text" id="ln_states" placeholder="FL, TX, GA"></label>
        <label class="field"><span>Loan minimum ($)</span><input type="number" id="ln_loanMin"></label>
        <label class="field"><span>Loan maximum ($)</span><input type="number" id="ln_loanMax"></label>
        <label class="field"><span>Max LTV (%)</span><input type="number" id="ln_maxLTV"></label>
        <label class="field"><span>Min DSCR (x)</span><input type="number" step="0.05" id="ln_minDSCR"></label>
        <label class="field"><span>Reserve requirement (months)</span><input type="number" id="ln_reserve"></label>
        <label class="field"><span>Max property age (years)</span><input type="number" id="ln_maxAge"></label>
        <label class="field" style="grid-column:1/3;"><span>Notes</span><input type="text" id="ln_notes"></label>
      </div>
      <button class="btn" id="ln_add" style="margin-top:12px;">Add lender</button>
    </div>`;
  body.querySelectorAll(".lenderDel").forEach(b=>b.onclick=()=>{LENDERS.splice(Number(b.dataset.i),1);renderLenders();renderOverview();});
  const add=body.querySelector("#ln_add");
  if(add)add.onclick=()=>{
    const v=id=>{const el=body.querySelector("#"+id);return el?el.value.trim():"";};
    const n=id=>{const x=v(id);return x===""?null:Number(x);};
    const name=v("ln_name");if(!name){alert("Enter a lender name.");return;}
    const states=v("ln_states").split(",").map(s=>s.trim().toUpperCase()).filter(Boolean);
    LENDERS.push({name,states,loanMin:n("ln_loanMin"),loanMax:n("ln_loanMax"),maxLTV:n("ln_maxLTV"),minDSCR:n("ln_minDSCR"),minReserveMonths:n("ln_reserve"),maxAge:n("ln_maxAge"),notes:v("ln_notes")});
    renderLenders();renderOverview();
  };
}

/* Wiring */
DEALS.forEach(hydrate);
DEALS.forEach((d,i)=>{ if(!d.status) d.status=["purchased","pipeline","purchasing","pipeline","pipeline","passed","pipeline","purchased","pipeline","purchasing"][i%10]||"pipeline"; });
document.querySelectorAll(".tab").forEach(t=>t.onclick=()=>{document.querySelectorAll(".tab").forEach(x=>x.classList.remove("active"));document.querySelectorAll(".panel").forEach(x=>x.classList.remove("active"));t.classList.add("active");document.getElementById("panel-"+t.dataset.tab).classList.add("active");const tb=t.dataset.tab;if(tb==="overview")renderOverview();else if(tb==="lenders")renderLenders();});
document.getElementById("filterRec").onchange=renderPipeline;
document.querySelectorAll("th.sortable").forEach(th=>th.onclick=()=>{const k=th.dataset.k;if(__sortKey===k)__sortDir*=-1;else{__sortKey=k;__sortDir=(k==="address")?1:-1;}renderPipeline();});
document.getElementById("modalX").onclick=()=>document.getElementById("modalBg").classList.remove("open");
document.getElementById("modalBg").onclick=e=>{if(e.target.id==="modalBg")e.currentTarget.classList.remove("open");};
document.getElementById("compX").onclick=()=>document.getElementById("compBg").classList.remove("open");
document.getElementById("compBg").onclick=e=>{if(e.target.id==="compBg")e.currentTarget.classList.remove("open");};
document.getElementById("compareBtn").onclick=openCompare;
document.getElementById("compareX").onclick=()=>document.getElementById("compareBg").classList.remove("open");
document.getElementById("compareBg").onclick=e=>{if(e.target.id==="compareBg")e.currentTarget.classList.remove("open");};
document.getElementById("printBtn").onclick=()=>window.print();
document.getElementById("comparePrint").onclick=()=>window.print();
document.getElementById("icBtn").onclick=()=>{__onepager=!__onepager;renderModal();};

function readForm(){const num=id=>{const v=document.getElementById(id).value;return v===""?null:Number(v);};const txt=id=>document.getElementById(id).value.trim()||undefined;const bb=num("t_buyback");const terms=applyTemplate({capital_deployed:num("t_basis"),sale_price:num("t_sale"),loan_balance:num("t_loan"),buyback_price_y2:bb,option_fee:num("t_option"),total_fees:num("t_fees"),monthly_rent:num("t_rent"),lease_term_months:num("t_term")},bb);return{client:txt("f_client"),address:txt("f_address"),city:txt("f_city"),state:txt("f_state"),zip:txt("f_zip"),terms,property:{market_value:num("f_market"),avm_confidence:num("f_market")!=null?"medium":"none"},facts:{},enrich:{}};}
document.getElementById("analyzeBtn").onclick=()=>{const d=readForm();hydrate(d);__active=d;document.getElementById("newResult").innerHTML=detailHTML(d);wireDetail("newResult");};
document.getElementById("saveBtn").onclick=()=>{const d=readForm();if(!d.address){alert("Enter at least an address.");return;}hydrate(d);DEALS.unshift(d);renderPipeline();document.querySelector('.tab[data-tab="pipeline"]').click();};

let bulkFmt="csv";const bulkHelp=document.getElementById("bulkHelp");
document.getElementById("fmtCsv").onclick=function(){bulkFmt="csv";this.classList.add("active");document.getElementById("fmtJson").classList.remove("active");bulkHelp.innerHTML='Paste rows from the Afford portfolio sheet. First row = headers (e.g. <code>Client Name, Address, Email, Year 2 Buyback</code>).';};
document.getElementById("fmtJson").onclick=function(){bulkFmt="json";this.classList.add("active");document.getElementById("fmtCsv").classList.remove("active");bulkHelp.innerHTML='Paste a JSON array of deals (each with <code>address</code>, <code>state</code>, and a <code>terms</code> object).';};
document.getElementById("loadSample").onclick=()=>{document.getElementById("bulkText").value=`Client Name,Address,Email,Year 2 Buyback\nSeth Teel,"764 N. Custer St, Wichita, KS 67203",travelingwholesale1@gmail.com,"$106,565.51"\nMichael Weis,"97 Chaplin St, Chaplin, CT 06235",,"$188,287.96"\nAdam Walker,"901 S. Santa Ana Dr, Tucson, AZ 85710",901santaana@gmail.com,"$200,945.67"`;bulkFmt="csv";document.getElementById("fmtCsv").click();};
document.getElementById("bulkImport").onclick=()=>{const msg=document.getElementById("bulkMsg");msg.textContent="";msg.className="";const text=document.getElementById("bulkText").value;try{let incoming;if(bulkFmt==="csv"){const r=parseDealsCsv(text);if(r.errors.length&&!r.deals.length)throw new Error(r.errors.join(" "));incoming=r.deals;}else{const p=JSON.parse(text);incoming=Array.isArray(p)?p:p.deals;if(!Array.isArray(incoming))throw new Error("Expected a JSON array.");}if(!incoming.length)throw new Error("No deals to import.");incoming.forEach(d=>{d.property=d.property||{market_value:null};d.facts=d.facts||{};d.enrich=d.enrich||{};if(d.property.avm_confidence==null)d.property.avm_confidence=d.property.market_value!=null?"medium":"none";hydrate(d);DEALS.unshift(d);});msg.className="ok-msg";msg.textContent=`Imported ${incoming.length} deal(s).`;renderPipeline();document.querySelector('.tab[data-tab="pipeline"]').click();}catch(e){msg.className="err-msg";msg.textContent=e.message;}};

function loadTemplateInputs(){tpl_fund.value=TEMPLATE.fundPct;tpl_option.value=TEMPLATE.optionPct;tpl_fees.value=TEMPLATE.feesPct;tpl_term.value=TEMPLATE.termMonths;tpl_rent.value=TEMPLATE.rentPctYr;tpl_stepup.value=TEMPLATE.stepUpPct;}
document.getElementById("saveTemplate").onclick=()=>{TEMPLATE.fundPct=Number(tpl_fund.value)||88;TEMPLATE.optionPct=Number(tpl_option.value)||7;TEMPLATE.feesPct=Number(tpl_fees.value)||9;TEMPLATE.termMonths=Number(tpl_term.value)||24;TEMPLATE.rentPctYr=Number(tpl_rent.value)||9;TEMPLATE.stepUpPct=Number(tpl_stepup.value)||8;document.getElementById("tplMsg").textContent="Saved — applied to new/imported deals.";};

function loadAssumptionInputs(){a_ratio.value=ASSUMPTIONS.fundingRatio;a_coc.value=ASSUMPTIONS.costOfCapitalPctPerYear*100;a_sell.value=ASSUMPTIONS.sellingCostPct*100;a_maint.value=ASSUMPTIONS.maintenancePctPerYear*100;a_hold.value=ASSUMPTIONS.defaultHoldYears;}
document.getElementById("applyAssumptions").onclick=()=>{ASSUMPTIONS.fundingRatio=Number(a_ratio.value)||0.88;ASSUMPTIONS.costOfCapitalPctPerYear=(Number(a_coc.value)||8)/100;ASSUMPTIONS.sellingCostPct=(Number(a_sell.value)||7)/100;ASSUMPTIONS.maintenancePctPerYear=(Number(a_maint.value)||1)/100;ASSUMPTIONS.defaultHoldYears=Number(a_hold.value)||2;rescoreAll();renderPipeline();document.querySelector('.tab[data-tab="pipeline"]').click();};

loadTemplateInputs();loadAssumptionInputs();renderPipeline();renderOverview();
</script>
