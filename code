function openCompare(){
  const sel=DEALS.filter(d=>__compare.has(d.id));if(sel.length<2)return;
  const rowsDef=[
    ["Recommendation",d=>chip(d.analysis.recommendation)],
    ["Confidence",d=>cap(d.analysis.confidence)],
