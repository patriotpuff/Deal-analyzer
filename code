<script>
const CURRENT_YEAR=2026, CURRENT_MONTH=5;
const ASSUMPTIONS={fundingRatio:0.88,sellingCostPct:0.07,maintenancePctPerYear:0.01,costOfCapitalPctPerYear:0.08,defaultHoldYears:2.0,defaultInsuranceAnnual:1500};
const TEMPLATE={fundPct:88,optionPct:7,feesPct:9,termMonths:24,rentPctYr:9,stepUpPct:8};
const CONF={none:0,low:1,medium:2,high:3};
const round1=x=>Math.round(x*10)/10, clamp=(x,a,b)=>Math.max(a,Math.min(b,x));
const STATE_TAX={AL:0.41,AK:1.19,AZ:0.62,AR:0.62,CA:0.74,CO:0.51,CT:2.14,DE:0.57,FL:0.89,GA:0.92,HI:0.28,ID:0.69,IL:2.27,IN:0.85,IA:1.57,KS:1.41,KY:0.86,LA:0.55,ME:1.36,MD:1.09,MA:1.23,MI:1.54,MN:1.12,MS:0.81,MO:0.97,MT:0.84,NE:1.73,NV:0.60,NH:2.18,NJ:2.49,NM:0.80,NY:1.72,NC:0.84,ND:0.98,OH:1.56,OK:0.90,OR:0.97,PA:1.58,RI:1.63,SC:0.57,SD:1.31,TN:0.71,TX:1.80,UT:0.63,VT:1.90,VA:0.82,WA:0.98,WV:0.58,WI:1.85,WY:0.61,DC:0.56};
const STATE_INS={AL:2400,AK:1200,AZ:1600,AR:2200,CA:1400,CO:2400,CT:1700,DE:1000,FL:4200,GA:1800,HI:1200,ID:1100,IL:1600,IN:1300,IA:1400,KS:2600,KY:1800,LA:3000,ME:1100,MD:1300,MA:1700,MI:1400,MN:1700,MS:2400,MO:1800,MT:1600,NE:2200,NV:1000,NH:1100,NJ:1300,NM:1500,NY:1600,NC:1700,ND:1600,OH:1200,OK:3200,OR:900,PA:1200,RI:1900,SC:1800,SD:2000,TN:1800,TX:3200,UT:900,VT:1000,VA:1300,WA:1100,WV:1200,WI:1100,WY:1200,DC:1100};
const DISASTER=new Set(["FL","LA","TX","CA","OK"]);

/* Local landlord–tenant stance by state (representative for this review — confirm
   current statutes with counsel). "lean" drives the badge; notes flag unique
   state rules that could affect a sale-leaseback acquisition (esp. equity-
   purchase / foreclosure-rescue statutes that give distressed sellers rescission
   rights). Blank/unknown states fall back to _default. */
const STATE_LEGAL={
  _default:{lean:"Balanced",eviction:"Eviction timeline and notice periods vary — verify county rules.",notes:["No state profile loaded — confirm landlord-tenant act, eviction timeline, and any foreclosure-rescue / equity-purchase statute before close."]},
  MO:{lean:"Landlord-friendly",eviction:"Rent-and-possession actions move fast (often 3–5 weeks); no statewide grace period required.",notes:["No statewide rent control (preempted).","Security-deposit cap of 2 months; return within 30 days.","Distressed-seller sale-leasebacks can trip Missouri Merchandising Practices Act scrutiny — document fair value + no misrepresentation."]},
  TN:{lean:"Landlord-friendly",eviction:"Detainer warrant ~2–4 weeks; URLTA applies in larger counties only.",notes:["No rent control (preempted statewide).","14-day notice for nonpayment under URLTA counties.","Strong growth corridor — verify the buyback isn't above a rising market."]},
  FL:{lean:"Landlord-friendly",eviction:"3-day notice for nonpayment; uncontested eviction often 3–4 weeks.",notes:["Rent control prohibited by statute.","No limit on security deposit amount.","High insurance + reinsurance cost is the real risk lever here, not tenant law.","Equity-purchase of homes in/near foreclosure is regulated — written contract + cancellation rights may apply."]},
  KS:{lean:"Landlord-friendly",eviction:"3-day notice; eviction commonly 2–4 weeks.",notes:["No rent control.","Security deposit capped at 1 month (1.5 if furnished).","Older housing stock common — confirm lender age limits don't block financing."]},
  IN:{lean:"Landlord-friendly",eviction:"10-day notice for nonpayment; eviction typically 3–6 weeks.",notes:["No rent control; broad landlord remedies.","Limited habitability case law relative to tenant-friendly states.","Population-declining micro-markets — weight resale exit carefully."]},
  NC:{lean:"Landlord-friendly",eviction:"Summary ejectment via magistrate court; ~3–5 weeks.",notes:["No rent control.","Late-fee cap (~5% / $15).","Coastal insurance + wind pool exposure in some counties."]},
  VA:{lean:"Balanced (landlord-leaning)",eviction:"Unlawful detainer ~4–8 weeks; VRLTA governs most rentals.",notes:["No rent control, but VRLTA adds tenant procedural protections.","Required written rental agreements + maintenance duties.","Confirm locality has no source-of-income or just-cause overlay."]},
  MI:{lean:"Balanced",eviction:"~3–6 weeks; Detroit has additional tenant protections.",notes:["Detroit: right-to-counsel program + stricter code enforcement / rental registration.","Distressed Detroit values can fall below buyback — underwrite resale conservatively.","Truth-in-renting act governs lease terms."]},
  CT:{lean:"Tenant-friendly",eviction:"Summary process can run 1–3 months; mediation common.",notes:["Stronger tenant defenses + longer timelines raise carrying cost.","Security-deposit limits (2 months; 1 if 62+).","Build extra hold-period reserve into the model."]},
  AZ:{lean:"Landlord-friendly",eviction:"5-day notice for nonpayment; eviction often 2–3 weeks.",notes:["Rent control prohibited.","Arizona Residential Landlord and Tenant Act is relatively landlord-favorable.","Heat/cooling habitability obligations in summer."]},
  GA:{lean:"Landlord-friendly",eviction:"Dispossessory ~2–4 weeks; no required cure period for nonpayment.",notes:["No rent control.","Residential Mortgage Fraud Act — keep sale-leaseback valuation + disclosures clean for distressed sellers."]},
  TX:{lean:"Landlord-friendly",eviction:"3-day notice; eviction commonly 3 weeks.",notes:["No rent control (preempted).","Fast, predictable eviction process.","Property-tax + insurance load is the main cost driver."]},
  CA:{lean:"Tenant-friendly",eviction:"Just-cause + long timelines; eviction often 2–4+ months.",notes:["Statewide rent cap + just-cause (AB 1482).","⚠ Home Equity Sales Contract Act (Civ. Code §1695): sale-leasebacks with owners in foreclosure require a specific contract, a 5-day right to cancel, and carry steep penalties — legal review mandatory.","High carrying cost on any contested exit."]},
  NY:{lean:"Tenant-friendly",eviction:"Lengthy; HSTPA protections; months-long timelines.",notes:["Strong rent-regulation regime in many areas.","Long eviction timelines materially raise carrying cost.","Treat as low priority unless legal + ops capacity exists."]},
  NJ:{lean:"Tenant-friendly",eviction:"Anti-Eviction Act limits grounds; timelines long.",notes:["Just-cause eviction statewide.","Higher procedural burden + reserves required."]},
  OH:{lean:"Landlord-friendly",eviction:"3-day notice; eviction ~3–5 weeks.",notes:["No rent control.","Reasonable landlord remedies; verify local code enforcement."]},
  PA:{lean:"Balanced",eviction:"10–15 day notice; eviction ~1–2 months.",notes:["No statewide rent control (Philadelphia has added tenant protections).","Confirm city-level just-cause / good-cause rules."]},
};

/* Lenders we work with for this product + their requirements. A BLANK field
   means NO requirement (the lender doesn't care about that parameter). */
let LENDERS=[
  {name:"Kiavi (DSCR rental)",            states:[],                          loanMin:75000, loanMax:2000000, maxLTV:80, minDSCR:1.10, minReserveMonths:6, maxAge:null, notes:"Interest-only DSCR; condition C4 or better; nationwide."},
  {name:"Lima One Capital",               states:[],                          loanMin:50000, loanMax:null,    maxLTV:75, minDSCR:1.20, minReserveMonths:6, maxAge:100,  notes:"Rental30 program; tighter DSCR."},
  {name:"Heartland Hard Money",           states:[],                          loanMin:30000, loanMax:250000,  maxLTV:65, minDSCR:null, minReserveMonths:null, maxAge:null, notes:"Asset-based — no DSCR / reserve test, but lower LTV."},
  {name:"Sunbelt Bridge Capital",         states:["FL","TX","AZ","GA","NC","SC"], loanMin:100000, loanMax:null, maxLTV:78, minDSCR:1.15, minReserveMonths:3, maxAge:60, notes:"Sunbelt only; newer stock."},
  {name:"Veterans Community CU (regional)",states:["MO","KS","TN","OK"],       loanMin:40000, loanMax:400000,  maxLTV:70, minDSCR:1.00, minReserveMonths:3, maxAge:null, notes:"Mission lender; lower max LTV, no age limit."},
];

function areaForState(state,conf){const st=(state||"").toUpperCase();const a={population_trend:"unknown",population_cagr_pct:null,home_price_trend:"unknown",home_price_yoy_pct:null,rent_trend:"unknown",property_tax_rate_pct:STATE_TAX[st]??null,property_tax_trend:"unknown",insurance_annual_est:STATE_INS[st]??null,insurance_trend:DISASTER.has(st)?"rising":"unknown",school_rating:null,school_trend:"unknown",litigation_risk:"unknown",data_confidence:(STATE_TAX[st]!=null?"low":"none")};if(conf)a.data_confidence=conf;return a;}
function buildArea(d){const a=areaForState(d.state,d.enrich&&d.enrich.data_confidence);const e=d.enrich||{};if(e.population_trend)a.population_trend=e.population_trend;if(e.population_cagr_pct!=null)a.population_cagr_pct=e.population_cagr_pct;if(e.home_price_trend)a.home_price_trend=e.home_price_trend;if(e.home_price_yoy!=null)a.home_price_yoy_pct=e.home_price_yoy;if(e.rent_trend)a.rent_trend=e.rent_trend;if(e.school_rating!=null)a.school_rating=e.school_rating;if(e.school_trend)a.school_trend=e.school_trend;if(e.insurance_trend)a.insurance_trend=e.insurance_trend;return a;}

function costBasis(t){if(t.capital_deployed!=null)return{v:t.capital_deployed,est:false};if(t.sale_price!=null)return{v:t.sale_price+(t.closing_costs||0),est:!!t._sale_est};if(t.contract_purchase_price!=null)return{v:t.contract_purchase_price+(t.closing_costs||0),est:false};if(t.net_proceeds_to_seller!=null)return{v:t.net_proceeds_to_seller+(t.closing_costs||0)+(t.mortgage_payoff||0),est:false};const bb=buyback(t);if(bb!=null)return{v:round1(bb*ASSUMPTIONS.fundingRatio),est:true};return{v:null,est:false};}
function buyback(t){return t.buyback_price_y2??t.buyback_price_y1??null;}
// Option fee: a flat cash amount, or a % of the sale price / loan balance / buyback.
function optionFee(t){if(!t)return 0;if(t.option_fee_mode==="pct"&&t.option_fee_pct!=null){const base=t.option_fee_basis==="loan_balance"?t.loan_balance:(t.option_fee_basis==="buyback"?buyback(t):(t.sale_price??t.capital_deployed));return base!=null?Math.round(base*t.option_fee_pct/100):0;}return t.option_fee||0;}
function holdYears(t){return(t.lease_term_months&&t.lease_term_months>0)?t.lease_term_months/12:ASSUMPTIONS.defaultHoldYears;}
function upfront(t){return optionFee(t)+(t.total_fees||0);}
function rentCollected(t,y){return t.monthly_rent?t.monthly_rent*Math.round(y*12):0;}
function carrying(value,basis,area,years){const v=value??basis;const tax=(area.property_tax_rate_pct!=null)?v*area.property_tax_rate_pct/100:0;const ins=area.insurance_annual_est??ASSUMPTIONS.defaultInsuranceAnnual;const maint=v*ASSUMPTIONS.maintenancePctPerYear;const cap=basis*ASSUMPTIONS.costOfCapitalPctPerYear;return(tax+ins+maint+cap)*years;}
function scenario(label,cashIn,basis,carry,years){const cashOut=basis+carry,net=cashIn-cashOut;const roi=basis>0?round1(net/basis*100):null;const ann=(roi!=null&&years>0)?round1(roi/years):null;return{label,cash_in:cashIn,cash_out:cashOut,net_profit:net,roi_pct:roi,annualized_roi_pct:ann,profitable:net>0};}

function analyze(input){
  const t=input.terms||{},p=input.property||{},area=input.area||{};
  const bi=costBasis(t),basis=bi.v;const value=(p.market_value!=null)?p.market_value:null;const bb=buyback(t),years=holdYears(t);
  let cushion=null,b2v=null,repurchase=null,resale=null;
  // Equity cushion = market vs the figure we choose to measure exposure against
  // (default = our capital deployed; can be sale price or loan balance per deal).
  const cushionRef=t.cushion_ref==="sale_price"?(t.sale_price??basis):(t.cushion_ref==="loan_balance"?(t.loan_balance??basis):basis);
  if(cushionRef!=null&&value!=null&&value>0)cushion=round1((value-cushionRef)/value*100);
  if(bb!=null&&value!=null&&value>0)b2v=round1(bb/value*100);
  if(basis!=null&&bb!=null)repurchase=scenario("repurchase",upfront(t)+rentCollected(t,years)+bb,basis,carrying(value,basis,area,years),years);
  if(basis!=null&&value!=null){const nr=value-value*ASSUMPTIONS.sellingCostPct;resale=scenario("default_resale",upfront(t)+rentCollected(t,years)+nr,basis,carrying(value,basis,area,years),years);}
  let risk=0,benefit=0;const factors=[],warnings=[];
  const R=(c,l,pp,d)=>{risk+=pp;factors.push({code:c,label:l,kind:"risk",points:pp,detail:d});};
  const B=(c,l,pp,d)=>{benefit+=pp;factors.push({code:c,label:l,kind:"benefit",points:pp,detail:d});};
  if(cushion!=null){if(cushion<0)R("underwater","Underwater on default",35,`Our basis exceeds market value by ${(-cushion).toFixed(1)}% — a default leaves us holding an asset worth less than we put in`);else if(cushion<10)R("thin_cushion","Thin equity cushion",20,`Only ${cushion.toFixed(1)}% equity cushion — little room for error on a forced sale`);else if(cushion<20)R("modest_cushion","Modest equity cushion",10,`${cushion.toFixed(1)}% equity cushion over our basis`);else if(cushion>=35)B("strong_cushion","Strong equity cushion",22,`${cushion.toFixed(1)}% equity cushion — collateral well covers our basis even on a default`);else B("adequate_cushion","Adequate equity cushion",12,`${cushion.toFixed(1)}% equity cushion over our basis`);}
  if(b2v!=null){if(b2v>105)R("buyback_above_market","Buyback exceeds market",25,`Buyback is ${b2v.toFixed(0)}% of market value — occupant would overpay to repurchase; expect a walk-away and resale loss`);else if(b2v>95)R("buyback_near_market","Buyback near market",10,`Buyback is ${b2v.toFixed(0)}% of market value — weak incentive to repurchase`);else if(b2v<85)B("buyback_below_market","Strong repurchase incentive",15,`Buyback is only ${b2v.toFixed(0)}% of market value — occupant has real equity to capture`);}
  if(repurchase){const r=repurchase.annualized_roi_pct;if(r!=null){if(r>=15)B("yield_high","High yield",20,`~${r.toFixed(1)}% annualized return if repurchased`);else if(r>=10)B("yield_good","Solid yield",12,`~${r.toFixed(1)}% annualized return if repurchased`);else if(r>=6)B("yield_modest","Modest yield",6,`~${r.toFixed(1)}% annualized return if repurchased`);else if(r<0)R("yield_negative","Negative yield",15,`~${r.toFixed(1)}% annualized return even if repurchased — the structure loses money`);}}
  if(resale){resale.profitable?B("resale_safe","Profitable on default",10,"Even if the occupant walks, reselling at market clears our basis and costs"):R("resale_loss","Loss on default",12,"If the occupant walks, a market resale does not recover our basis and costs");}
  if(p.pre_foreclosure)R("pre_foreclosure","Pre-foreclosure",18,"Property is in pre-foreclosure");
  if(p.auction)R("auction","Auction",18,"Property is scheduled for auction");
  if(p.has_liens)R("liens","Liens on title",10,"Outstanding liens recorded against the property");
  if(p.in_flood_zone)R("flood_zone","Flood zone",10,"Property sits in a flood zone");
  if(p.vacant)R("vacant","Vacant",8,"Property is currently vacant");
  if(area.population_trend==="falling")R("pop_falling","Population declining",12,"Area population is shrinking — softer demand and weaker future resale");else if(area.population_trend==="rising")B("pop_rising","Population growing",12,"Area population is growing — stronger demand supports value and rent");
  if(area.home_price_trend==="falling")R("price_falling","Home prices falling",12,"Local home prices are declining — the equity cushion erodes");else if(area.home_price_trend==="rising")B("price_rising","Home prices rising",10,"Local home prices are rising — the cushion grows");
  if(area.rent_trend==="falling")R("rent_falling","Rents falling",6,"Local rents are declining");else if(area.rent_trend==="rising")B("rent_rising","Rents rising",6,"Local rents are rising");
  if(area.property_tax_trend==="rising")R("tax_rising","Property taxes rising",5,"Property taxes trending up");
  if(area.insurance_trend==="rising")R("insurance_rising","Insurance rising",6,"Insurance premiums trending up");
  if(area.school_rating!=null&&area.school_rating<4)R("schools_weak","Weak schools",5,`Schools rate ${area.school_rating.toFixed(1)}/10`);else if(area.school_rating!=null&&area.school_rating>=7)B("schools_strong","Strong schools",6,`Schools rate ${area.school_rating.toFixed(1)}/10`);
  if(area.school_trend==="falling")R("schools_declining","Schools declining",5,"School quality trending down");
  if(area.litigation_risk==="rising")R("litigation","High litigation risk",8,"Elevated landlord-tenant litigation risk");
  const b=input.borrower;
  if(b){
    if(b.credit_score!=null){const s=b.credit_score;
      if(s>=700)B("credit_strong","Strong borrower credit",8,`Credit ${s} — likely to qualify to refinance/repurchase at the buyback`);
      else if(s>=640)B("credit_fair","Fair borrower credit",3,`Credit ${s} — has a path to qualify, with seasoning`);
      else if(s<580)R("credit_poor","Poor borrower credit",8,`Credit ${s} — unlikely to qualify to repurchase; expect a hold/resale outcome`);
      else R("credit_weak","Sub-prime borrower credit",3,`Credit ${s} — repurchase financing is a stretch`);}
    if(b.estimated_dti_pct!=null){const dd=b.estimated_dti_pct;if(dd>45)R("dti_high","High debt-to-income",6,`~${dd.toFixed(0)}% housing DTI — thin capacity to carry/repurchase`);else if(dd<=36&&dd>0)B("dti_low","Comfortable DTI",3,`~${dd.toFixed(0)}% housing DTI`);}
    if(b.bankruptcy)R("bankruptcy","Bankruptcy on file",6,"A bankruptcy on file lengthens the road back to mortgage qualification");
    if(b.intent){const i=b.intent.toLowerCase();if(i.includes("sell"))R("intent_sell","Intends to sell",2,"Occupant intends to sell rather than repurchase — plan for a resale exit");else if(i.includes("repurchase")||i.includes("refinance")||i.includes("buyback")||i.includes("mortgage")||i.includes("remortgage"))B("intent_repurchase","Intends to repurchase",4,"Occupant intends to refinance/repurchase — aligned with the buyback exit");}
  }
  let conf=Math.min(CONF[p.avm_confidence||"none"],CONF[area.data_confidence||"none"]);
  if(conf===CONF.none&&value!=null)conf=CONF.low;
  const hasAll=basis!=null&&value!=null&&bb!=null;if(!hasAll)conf=Math.min(conf,CONF.low);
  if(conf<=CONF.low){R("data_confidence","Thin data",10,"Key inputs are missing or low-confidence — verify");warnings.push("Analysis confidence is low; treat the recommendation as directional only");}
  const riskScore=clamp(risk,0,100),benefitScore=clamp(benefit,0,100);
  let rec;
