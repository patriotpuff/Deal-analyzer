<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="Deal Analyzer" />
<meta name="theme-color" content="#0b1f3a" />
<meta name="format-detection" content="telephone=no" />
<link rel="manifest" href="manifest.webmanifest" />
<link rel="apple-touch-icon" href="icon-180.png" />
<link rel="icon" type="image/png" sizes="192x192" href="icon-192.png" />
<title>VAB — Acquisition Deal Analyzer</title>
<style>
  :root{
    --navy:#0b1f3a;--navy2:#13294b;--ink:#0f172a;--muted:#64748b;--faint:#94a3b8;
    --line:#e6eaf0;--bg:#eef1f6;--card:#fff;--brand:#1d65d8;--brand2:#3b82f6;
    --green:#0f7a47;--green-bg:#e7f6ee;--green-line:#bfe6cf;
    --amber:#9a6a00;--amber-bg:#fdf3da;--amber-line:#f0dba0;
    --red:#bb2418;--red-bg:#fde7e4;--red-line:#f4c2bc;
    --gray:#475569;--gray-bg:#eef1f5;
    --shadow:0 1px 2px rgba(15,23,42,.06),0 8px 24px rgba(15,23,42,.06);
    --shadow-lg:0 10px 40px rgba(11,31,58,.18);
  }
  *{box-sizing:border-box;}
  body{margin:0;font-family:"Inter",-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;background:var(--bg);color:var(--ink);font-size:14px;line-height:1.45;-webkit-font-smoothing:antialiased;}
  h1,h2,h3,h4{margin:0;font-weight:700;letter-spacing:-.01em;}
  code{background:#eef1f5;padding:1px 5px;border-radius:5px;font-size:12px;}
  header{background:radial-gradient(1200px 200px at 20% -40%,#1c3f73,transparent),linear-gradient(180deg,var(--navy),var(--navy2));color:#fff;padding:20px 26px;}
  header .title{font-size:21px;font-weight:800;} header .sub{color:#aabbd6;font-size:12.5px;margin-top:3px;}
  .wrap{max-width:1200px;margin:0 auto;padding:22px 26px 70px;}
  .banner{background:linear-gradient(180deg,#fffaf0,#fff7e6);border:1px solid #f0dba0;color:#7a5a00;border-radius:12px;padding:12px 15px;font-size:12.5px;margin-bottom:18px;}
  .tabs{display:flex;gap:4px;background:#fff;border:1px solid var(--line);border-radius:12px;padding:5px;margin-bottom:20px;box-shadow:var(--shadow);width:fit-content;flex-wrap:wrap;}
  .tab{padding:8px 16px;border:none;background:none;cursor:pointer;font-size:13.5px;font-weight:600;color:var(--muted);border-radius:8px;}
  .tab.active{color:#fff;background:linear-gradient(180deg,var(--brand2),var(--brand));}
  .panel{display:none;} .panel.active{display:block;}
  .cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin-bottom:18px;}
  .stat{background:var(--card);border:1px solid var(--line);border-radius:13px;padding:14px 16px;box-shadow:var(--shadow);}
  .stat .k{font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);font-weight:700;}
  .stat .v{font-size:23px;font-weight:800;margin-top:3px;letter-spacing:-.02em;} .stat .v.sm{font-size:17px;}
  .toolbar{display:flex;gap:10px;align-items:center;margin-bottom:14px;flex-wrap:wrap;}
  select,input[type=text],input[type=number],textarea{border:1px solid #cbd5e1;border-radius:9px;padding:8px 11px;background:#fff;font:inherit;}
  .btn{background:linear-gradient(180deg,var(--brand2),var(--brand));color:#fff;border:none;border-radius:9px;padding:9px 17px;font-weight:700;cursor:pointer;box-shadow:var(--shadow);}
  .btn:hover{filter:brightness(1.05);} .btn.ghost{background:#fff;color:var(--ink);border:1px solid #cbd5e1;box-shadow:none;} .btn.dark{background:linear-gradient(180deg,#1c3f73,var(--navy));}
  .note{font-size:12px;color:var(--muted);}
  table{width:100%;border-collapse:collapse;background:var(--card);border:1px solid var(--line);border-radius:13px;overflow:hidden;box-shadow:var(--shadow);}
  th,td{padding:11px 13px;text-align:left;border-bottom:1px solid #f1f4f8;}
  th{background:#f8fafc;font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);font-weight:700;}
  td.num,th.num{text-align:right;font-variant-numeric:tabular-nums;}
  tbody tr{transition:background .12s;} tbody tr.click:hover{background:#f6f9ff;cursor:pointer;} tbody tr:last-child td{border-bottom:none;}
  .chip{display:inline-flex;align-items:center;gap:5px;border-radius:7px;padding:3px 9px;font-size:11.5px;font-weight:800;border:1px solid transparent;}
  .chip.proceed{background:var(--green-bg);color:var(--green);border-color:var(--green-line);}
  .chip.conditional{background:var(--amber-bg);color:var(--amber);border-color:var(--amber-line);}
  .chip.pass{background:var(--red-bg);color:var(--red);border-color:var(--red-line);}
  .chip.insufficient_data{background:var(--gray-bg);color:var(--gray);border-color:#d7dde6;}
  .est{font-size:9.5px;font-weight:800;color:#7a5a00;background:#fdf3da;border:1px solid #f0dba0;border-radius:5px;padding:0 4px;margin-left:5px;vertical-align:middle;text-transform:uppercase;}
  .risk-low{color:var(--green);} .risk-medium{color:#9a6a00;} .risk-high{color:#c2410c;} .risk-critical{color:var(--red);}
  .card{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:18px;box-shadow:var(--shadow);}
  .card h3{font-size:12px;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:13px;}
  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:16px;} .grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
  @media(max-width:860px){.grid2,.grid3{grid-template-columns:1fr;}}
  label.field{display:block;margin-bottom:11px;} label.field span{font-size:12px;color:#475569;font-weight:600;display:block;margin-bottom:4px;} label.field input{width:100%;}
  .formgrid{display:grid;grid-template-columns:1fr 1fr;gap:11px;}
  .metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:11px;} @media(max-width:640px){.metrics{grid-template-columns:1fr 1fr;}}
  .metric{border:1px solid var(--line);border-radius:11px;padding:12px 13px;background:linear-gradient(180deg,#fff,#fbfcfe);}
  .metric .k{font-size:10.5px;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);font-weight:700;} .metric .v{font-size:18px;font-weight:800;margin-top:3px;} .metric .h{font-size:11px;color:var(--faint);}
  .bar{height:9px;background:#eef1f5;border-radius:99px;overflow:hidden;margin-top:6px;} .bar>span{display:block;height:100%;border-radius:99px;}
  .bar.risk>span{background:linear-gradient(90deg,#f08a6e,#e0533f);} .bar.benefit>span{background:linear-gradient(90deg,#43c98a,#0f7a47);}
  .scen{border:1px solid var(--line);border-radius:11px;padding:14px;background:linear-gradient(180deg,#fff,#fbfcfe);}
  .scen .top{display:flex;justify-content:space-between;align-items:center;margin-bottom:9px;}
  .scen dl{display:grid;grid-template-columns:1fr auto;gap:4px 12px;margin:0;font-size:13px;} .scen dt{color:var(--muted);} .scen dd{margin:0;text-align:right;font-variant-numeric:tabular-nums;}
  .pos{color:var(--green);} .neg{color:var(--red);}
  .factors{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:6px;} @media(max-width:640px){.factors{grid-template-columns:1fr;}}
  .factor{display:flex;gap:9px;align-items:flex-start;font-size:13px;margin-bottom:8px;} .pts{font-size:11px;font-weight:800;border-radius:5px;padding:1px 6px;flex:none;margin-top:1px;}
  .pts.risk{background:var(--red-bg);color:var(--red);} .pts.benefit{background:var(--green-bg);color:var(--green);}
  .warn{background:var(--amber-bg);border:1px solid var(--amber-line);color:var(--amber);border-radius:11px;padding:11px 13px;font-size:13px;margin:14px 0;}
  .modal-bg{position:fixed;inset:0;background:rgba(11,31,58,.5);backdrop-filter:blur(2px);display:none;z-index:60;overflow:auto;} .modal-bg.open{display:block;}
  .sheet{background:var(--bg);max-width:1080px;margin:30px auto;border-radius:18px;overflow:hidden;box-shadow:var(--shadow-lg);}
  .sheet .closebar{position:sticky;top:0;z-index:5;display:flex;justify-content:flex-end;padding:10px 14px;}
  .sheet .x{border:none;background:rgba(255,255,255,.92);width:34px;height:34px;border-radius:50%;font-size:20px;cursor:pointer;color:#334155;box-shadow:var(--shadow);}
  .sheet .body{padding:0 22px 26px;}
  .compsheet{max-width:680px;}
  .hero{display:grid;grid-template-columns:1.3fr 1fr;gap:18px;margin-top:0;} @media(max-width:820px){.hero{grid-template-columns:1fr;}}
  .gallery{margin-top:-44px;} @media(max-width:820px){.gallery{margin-top:0;}}
  .gallery .main{aspect-ratio:16/10;border-radius:14px;overflow:hidden;box-shadow:var(--shadow);background:#dbe3ee;} .gallery .main img{width:100%;height:100%;object-fit:cover;display:block;}
  .gallery .thumbs{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:8px;} .gallery .thumbs img{width:100%;aspect-ratio:4/3;object-fit:cover;border-radius:9px;cursor:pointer;border:2px solid transparent;} .gallery .thumbs img.active{border-color:var(--brand);}
  .heroinfo{background:#fff;border:1px solid var(--line);border-radius:14px;padding:18px;box-shadow:var(--shadow);display:flex;flex-direction:column;}
  .heroinfo .addr{font-size:20px;font-weight:800;} .heroinfo .loc{color:var(--muted);font-size:13px;margin-top:2px;}
  .pills{display:flex;flex-wrap:wrap;gap:7px;margin:14px 0;} .pill{background:#f1f5fb;border:1px solid #e2e8f3;border-radius:8px;padding:5px 9px;font-size:12px;font-weight:600;color:#334155;} .pill b{font-weight:800;}
  .bigval{margin-top:auto;} .bigval .lab{font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);font-weight:700;} .bigval .amt{font-size:30px;font-weight:800;}
  .section{margin-top:18px;} .secttitle{font-size:13px;font-weight:800;letter-spacing:.3px;color:var(--navy);margin:0 0 10px;text-transform:uppercase;}
  .appr{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;} @media(max-width:640px){.appr{grid-template-columns:1fr;}}
  .apprcol{border:1px solid var(--line);border-radius:12px;padding:14px;text-align:center;background:linear-gradient(180deg,#fff,#f7fbff);} .apprcol .yr{font-size:11px;font-weight:700;text-transform:uppercase;color:var(--muted);} .apprcol .val{font-size:22px;font-weight:800;margin:6px 0 2px;} .apprcol .gain{font-size:12.5px;font-weight:700;} .apprbar{height:7px;border-radius:99px;background:#eaf0f8;margin-top:10px;overflow:hidden;} .apprbar>span{display:block;height:100%;background:linear-gradient(90deg,#5aa0ff,#1d65d8);}
  .kv{display:grid;grid-template-columns:1fr auto;gap:7px 14px;font-size:13.5px;} .kv dt{color:var(--muted);} .kv dd{margin:0;text-align:right;font-weight:600;font-variant-numeric:tabular-nums;}
  .trend{font-weight:800;font-size:12px;padding:2px 7px;border-radius:6px;} .trend.rising{background:var(--green-bg);color:var(--green);} .trend.falling{background:var(--red-bg);color:var(--red);} .trend.stable{background:#eef2f7;color:#475569;} .trend.unknown{background:#f1f5f9;color:#94a3b8;}
  .areagrid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;} @media(max-width:760px){.areagrid{grid-template-columns:1fr 1fr;}}
  .acard{border:1px solid var(--line);border-radius:12px;padding:13px;background:#fff;} .acard .t{font-size:11px;text-transform:uppercase;color:var(--muted);font-weight:700;} .acard .m{font-size:19px;font-weight:800;margin:4px 0;} .acard .s{font-size:12px;color:var(--faint);}
  .school-dots{display:inline-flex;gap:2px;margin-left:6px;} .school-dots i{width:7px;height:7px;border-radius:50%;background:#e2e8f0;display:inline-block;} .school-dots i.on{background:#1d65d8;}
  .row-between{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;margin-bottom:14px;}
  .seg{display:inline-flex;border:1px solid #cbd5e1;border-radius:9px;overflow:hidden;} .seg button{border:none;background:#fff;padding:7px 13px;cursor:pointer;font-weight:700;color:#64748b;font-size:13px;} .seg button.active{background:var(--navy);color:#fff;}
  textarea{width:100%;min-height:240px;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:12px;}
  .ok-msg{color:var(--green);font-weight:700;} .err-msg{color:var(--red);font-weight:700;}
  th.sortable{cursor:pointer;user-select:none;} th.sortable:hover{color:var(--brand);} th.sortable.asc::after{content:" ▲";font-size:9px;} th.sortable.desc::after{content:" ▼";font-size:9px;}
  .chartwrap{position:relative;} .chartGuide{position:absolute;top:14px;bottom:30px;width:1px;background:var(--brand);opacity:.45;pointer-events:none;display:none;} .chartTip{position:absolute;top:6px;background:#0b1f3a;color:#fff;font-size:11px;font-weight:600;border-radius:7px;padding:5px 9px;pointer-events:none;display:none;white-space:nowrap;box-shadow:var(--shadow);z-index:3;}
  .mapdot{cursor:pointer;transition:opacity .1s;} .mapdot:hover{opacity:.75;} .maploading{padding:48px 20px;text-align:center;color:var(--muted);font-size:13px;background:linear-gradient(180deg,#eef4fb,#e2ebf7);border-radius:12px;border:1px solid var(--line);} .maplegend{display:flex;gap:14px;flex-wrap:wrap;font-size:12px;color:var(--muted);margin-top:8px;} .maplegend span{display:inline-flex;align-items:center;gap:5px;} .maplegend i{width:10px;height:10px;border-radius:50%;display:inline-block;}
  .cmptable th,.cmptable td{white-space:nowrap;} .cmptable td.metric{font-weight:600;color:var(--muted);position:sticky;left:0;background:#fff;}
  .sensgrid{display:grid;grid-template-columns:1fr 1fr;gap:14px 22px;} @media(max-width:640px){.sensgrid{grid-template-columns:1fr;}}
  .sensgrid label{display:block;font-size:12px;font-weight:600;color:#475569;} .sensgrid label b{float:right;color:var(--ink);} .sensgrid input[type=range]{width:100%;margin-top:8px;accent-color:var(--brand);}
  .onepager{background:#fff;border:1px solid var(--line);border-radius:12px;padding:24px;} .onepager h1{font-size:20px;} .op-rec{font-size:13px;}
  .op-head{display:flex;justify-content:space-between;align-items:flex-start;border-bottom:2px solid var(--navy);padding-bottom:12px;margin-bottom:14px;}
  .op-cols{display:grid;grid-template-columns:1fr 1fr;gap:22px;} @media(max-width:640px){.op-cols{grid-template-columns:1fr;}}
  .op-sign{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:20px;padding-top:14px;border-top:1px solid var(--line);} .op-sign div{font-size:12px;color:var(--muted);} .op-sign .sigline{border-bottom:1px solid #94a3b8;height:26px;margin-bottom:4px;}
  @media print{
    header,.tabs,.banner,.panel,.closebar{display:none!important;}
    body{background:#fff;}
    .modal-bg{position:static!important;background:none!important;backdrop-filter:none!important;overflow:visible!important;display:none;}
    .modal-bg.open{display:block!important;}
    #compBg{display:none!important;}
    .sheet{box-shadow:none!important;margin:0!important;max-width:100%!important;background:#fff!important;border-radius:0;}
    .sheet .body{padding:0!important;}
    .hero{margin-top:0!important;} .gallery{margin-top:0!important;}
    .rangebtns,.termsedit,#applyTerms,.seg,.chartGuide,.chartTip{display:none!important;}
    .card,table,.section,.scen,.metric{break-inside:avoid;}
    @page{margin:14mm;}
  }
  .src-badge{font-size:9.5px;font-weight:800;text-transform:uppercase;border-radius:5px;padding:1px 5px;margin-left:6px;} .src-live{background:#e7f0ff;color:#1d4ed8;border:1px solid #c7dbff;} .src-sample{background:#f1f5f9;color:#64748b;border:1px solid #dde3ea;} .src-canopy{background:#eafbf3;color:#0f7a47;border:1px solid #bfe6cf;}
  .rangebtns{display:inline-flex;gap:5px;} .rangebtns button{border:1px solid #cbd5e1;background:#fff;border-radius:7px;padding:4px 11px;font-size:12px;font-weight:700;color:#475569;cursor:pointer;} .rangebtns button.active{background:var(--brand);color:#fff;border-color:var(--brand);}
  .capex td .lvl{font-weight:800;font-size:11px;padding:1px 7px;border-radius:6px;} .lvl.high{background:var(--red-bg);color:var(--red);} .lvl.medium{background:var(--amber-bg);color:var(--amber);} .lvl.low{background:var(--green-bg);color:var(--green);}
  .credit-badge{font-weight:800;border-radius:8px;padding:3px 10px;font-size:13px;} .credit-exc{background:var(--green-bg);color:var(--green);} .credit-good{background:#e7f0ff;color:#1d4ed8;} .credit-fair{background:var(--amber-bg);color:var(--amber);} .credit-poor{background:var(--red-bg);color:var(--red);} .credit-unknown{background:#f1f5f9;color:#94a3b8;}
  .wf{font-size:13.5px;} .wf .line{display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px dashed #eef1f5;} .wf .line.tot{border-top:2px solid #e2e8f0;border-bottom:none;font-weight:800;margin-top:4px;padding-top:8px;} .wf .amt{font-variant-numeric:tabular-nums;}
  .termsedit{display:grid;grid-template-columns:repeat(3,1fr);gap:9px;margin-bottom:12px;} @media(max-width:640px){.termsedit{grid-template-columns:1fr 1fr;}}
  .termsedit label{display:block;font-size:11px;color:#475569;font-weight:600;margin-bottom:3px;white-space:nowrap;} .termsedit input,.termsedit select{width:100%;padding:6px 8px;border:1px solid #cbd5e1;border-radius:7px;background:#fff;font:inherit;}
  /* ---- iPad / touch tuning (additive; no effect on desktop logic) ---- */
  html{-webkit-text-size-adjust:100%;text-size-adjust:100%;}
  *{-webkit-tap-highlight-color:rgba(0,0,0,0);}
  .modal-bg{-webkit-backdrop-filter:blur(2px);}
  header{padding-top:calc(20px + env(safe-area-inset-top));}
  .wrap{padding-left:calc(26px + env(safe-area-inset-left));padding-right:calc(26px + env(safe-area-inset-right));}
  @media (pointer:coarse){
    select,input[type=text],input[type=number],textarea{font-size:16px;}  /* stops iOS auto-zoom on tap */
  }
  @media (max-width:900px){
    #panel-pipeline table,#panel-lenders table{display:block;overflow-x:auto;-webkit-overflow-scrolling:touch;}
  }
</style>
</head>
<body>
<header>
  <div class="title">VAB — Acquisition Deal Analyzer</div>
  <div class="sub">Sale-leaseback / buyback underwriting · property + borrower + insurance intelligence · RealEstateAPI · Canopy Connect · CIC tri-merge credit · US Census</div>
</header>
<div class="wrap">
  <div class="banner"><b>Review prototype — runs entirely in your browser.</b> Scoring mirrors the production Rust <code>deal-analyzer</code>.
    Source badges: <span class="src-badge src-live">live</span> RealEstateAPI / Census, <span class="src-badge src-canopy">canopy</span> Canopy Connect (insurance + condition),
    <span class="src-badge src-sample">sample</span> representative seed for this review. Estimated basis is badged <span class="est">est</span>.</div>
  <div class="tabs">
    <button class="tab active" data-tab="overview">Overview</button>
    <button class="tab" data-tab="pipeline">Pipeline</button>
    <button class="tab" data-tab="new">New Analysis</button>
    <button class="tab" data-tab="bulk">Bulk Import</button>
    <button class="tab" data-tab="template">Deal Template</button>
    <button class="tab" data-tab="assumptions">Assumptions</button>
    <button class="tab" data-tab="lenders">Lenders</button>
  </div>

  <section class="panel active" id="panel-overview">
    <div id="overviewBody"></div>
  </section>

  <section class="panel" id="panel-pipeline">
    <div class="cards" id="summary"></div>
    <div class="card" id="portfolioMap" style="margin-bottom:18px;"></div>
    <div class="toolbar">
      <select id="filterRec"><option value="">All recommendations</option><option value="proceed">Proceed</option><option value="conditional">Conditional</option><option value="pass">Pass</option><option value="insufficient_data">Insufficient data</option></select>
      <button class="btn ghost" id="compareBtn" disabled>Compare (0)</button>
      <span class="note" id="count"></span>
    </div>
    <table><thead><tr><th style="width:30px"></th><th class="sortable" data-k="address">Property</th><th>Bd/Ba</th><th class="sortable" data-k="recommendation">Recommendation</th><th class="num sortable" data-k="market_value">Market</th><th class="num sortable" data-k="buyback_price">Buyback</th><th class="num sortable" data-k="monthly_rent">Rent/mo</th><th class="num sortable" data-k="equity_cushion_pct">Cushion</th><th class="num sortable" data-k="tenyr">10-yr value</th><th class="num sortable" data-k="risk_score">Risk</th></tr></thead><tbody id="pipelineBody"></tbody></table>
    <div class="note">Click any row for the full property dossier — value graph, comps, borrower, insurance, CapEx forecast &amp; income projection.</div>
  </section>

  <section class="panel" id="panel-new">
    <div class="grid2">
      <div>
        <div class="card" style="margin-bottom:16px;"><h3>Property</h3><div class="formgrid">
          <label class="field" style="grid-column:1/3;"><span>Address</span><input type="text" id="f_address" placeholder="182 Raintree Rd"></label>
          <label class="field"><span>City</span><input type="text" id="f_city"></label><label class="field"><span>State</span><input type="text" id="f_state" maxlength="2"></label>
          <label class="field"><span>ZIP</span><input type="text" id="f_zip"></label><label class="field"><span>Market value ($)</span><input type="number" id="f_market"></label>
