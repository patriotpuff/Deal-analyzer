const MAP_CDN={d3:"https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js",topo:"https://cdn.jsdelivr.net/npm/topojson-client@3/dist/topojson-client.min.js",atlas:"https://cdn.jsdelivr.net/npm/us-atlas@3/states-10m.json"};
let _mapLibs=null,_usTopo=null;
function loadScript(src,ready){return new Promise((res,rej)=>{if(ready()){res();return;}const s=document.createElement("script");s.src=src;s.onload=()=>res();s.onerror=()=>rej(new Error("load "+src));document.head.appendChild(s);});}
function ensureMap(){if(_mapLibs)return _mapLibs;_mapLibs=loadScript(MAP_CDN.d3,()=>!!window.d3).then(()=>loadScript(MAP_CDN.topo,()=>!!window.topojson)).then(()=>_usTopo?_usTopo:fetch(MAP_CDN.atlas).then(r=>{if(!r.ok)throw new Error("atlas "+r.status);return r.json();})).then(t=>(_usTopo=t));return _mapLibs;}
function renderMap(rows){
  const el=document.getElementById("portfolioMap");if(!el)return;
  if(window.d3&&window.topojson&&_usTopo){drawMap(el,rows,_usTopo);return;}
  el.innerHTML=`<h3>Portfolio map <span class="note" style="text-transform:none;letter-spacing:0;">· loading…</span></h3><div class="maploading">Loading U.S. map…</div>`;
  ensureMap().then(us=>drawMap(el,rows,us)).catch(()=>{const l=el.querySelector(".maploading");if(l)l.textContent="Map data couldn’t load (no network). The property list below is unaffected.";});
}
function drawMap(el,rows,us){
  const d3=window.d3,topojson=window.topojson,W=975,H=610;
  const states=topojson.feature(us,us.objects.states).features;
  const nation=topojson.feature(us,us.objects.nation);
  const interior=topojson.mesh(us,us.objects.states,(a,b)=>a!==b);
  const proj=d3.geoAlbersUsa().fitExtent([[8,8],[W-8,H-8]],nation);
  const path=d3.geoPath(proj);
  const stateFills=states.map(f=>`<path d="${path(f)}" fill="#eaf1fa"/>`).join("");
  const pts=rows.map(d=>{const c=dealCoord(d);return{d,xy:c?proj([c[1],c[0]]):null};}).filter(p=>p.xy);
  const seen={};
  const dots=pts.map(p=>{const k=p.xy[0].toFixed(0)+","+p.xy[1].toFixed(0);const i=(seen[k]=(seen[k]||0)+1)-1;const ang=i*2.39996,rad=i?10+i*2:0;const x=p.xy[0]+Math.cos(ang)*rad,y=p.xy[1]+Math.sin(ang)*rad;const a=p.d.analysis;const r=a.market_value?Math.max(7,Math.min(20,Math.sqrt(a.market_value)/40)):7;const col=REC_COLOR[a.recommendation];return `<circle class="mapdot" data-id="${p.d.id}" cx="${x.toFixed(1)}" cy="${y.toFixed(1)}" r="${r.toFixed(1)}" fill="${col}" fill-opacity="0.82" stroke="#fff" stroke-width="1.8"><title>${(p.d.client||p.d.address||'')} — ${[p.d.city,p.d.state].filter(Boolean).join(', ')}\n${RECLABEL[a.recommendation]} · ${money(a.market_value)}</title></circle>`;}).join("");
  const legend=Object.entries(REC_COLOR).map(([k,c])=>`<span><i style="background:${c}"></i>${RECLABEL[k]}</span>`).join("");
  el.innerHTML=`<h3>Portfolio map <span class="note" style="text-transform:none;letter-spacing:0;">· all 50 states (Alaska &amp; Hawaii inset) · bubble size = market value</span></h3>
    <svg viewBox="0 0 ${W} ${H}" width="100%" style="display:block;background:linear-gradient(180deg,#eef4fb,#e2ebf7);border-radius:12px;border:1px solid var(--line);">
      <path d="${path(nation)}" fill="#f7faff"/>
      ${stateFills}
      <path d="${path(interior)}" fill="none" stroke="#9db1cd" stroke-width="0.7"/>
      <path d="${path(nation)}" fill="none" stroke="#6f88ab" stroke-width="1.1"/>
      ${dots}</svg><div class="maplegend">${legend}</div>`;
  el.querySelectorAll(".mapdot").forEach(c=>c.onclick=()=>openDetail(c.dataset.id));
}
let __sortKey=null,__sortDir=-1,__compare=new Set();
