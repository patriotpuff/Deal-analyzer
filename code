const chip=r=>`<span class="chip ${r}">${RECLABEL[r]||r}</span>`;
/* Pipeline-table recommendation chip with a hover tooltip explaining WHY the
   engine landed on Proceed / Conditional / Pass — composed from the risk
   factors, benefit factors, and any warnings the analyzer raised. Avoids
   having to open each deal's dossier just to read the rationale. */
function chipExplained(a){
  const reasonLines=[];
  const fs=(a&&a.factors)||[];
  const risks=fs.filter(f=>f.kind==="risk");
  const bens=fs.filter(f=>f.kind==="benefit");
  reasonLines.push(`${(RECLABEL[a.recommendation]||a.recommendation)} — Risk ${a.risk_score} (${a.risk_level}) · Benefit ${a.benefit_score} · Confidence ${a.confidence}`);
  if(a.equity_cushion_pct!=null)reasonLines.push(`Cushion ${a.equity_cushion_pct.toFixed(1)}% · Buyback-to-value ${a.buyback_to_value_pct!=null?a.buyback_to_value_pct.toFixed(0)+'%':'—'}`);
  if(risks.length){reasonLines.push("");reasonLines.push("RISKS:");risks.forEach(f=>reasonLines.push(`  − ${f.label} (${f.points}) — ${f.detail}`));}
  if(bens.length){reasonLines.push("");reasonLines.push("BENEFITS:");bens.forEach(f=>reasonLines.push(`  + ${f.label} (${f.points}) — ${f.detail}`));}
  if(a.warnings&&a.warnings.length){reasonLines.push("");reasonLines.push("WARNINGS:");a.warnings.forEach(w=>reasonLines.push(`  ! ${w}`));}
  /* `title` attr supports newlines; escape quotes/angle-brackets to keep markup safe. */
  const tip=reasonLines.join("\n").replace(/[&<>"']/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;"}[c]));
  return `<span class="chip ${a.recommendation}" title="${tip}" style="cursor:help;">${RECLABEL[a.recommendation]||a.recommendation}</span>`;
}
