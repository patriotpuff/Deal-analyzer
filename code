/* Live sensitivity what-if (does not mutate the saved deal). */
function sensitivityBlock(d){if(d.analysis.market_value==null||d.analysis.cost_basis==null)return "";
  const mv=d.analysis.market_value,bb=d.terms.buyback_price_y2||d.analysis.buyback_price||0,term=d.terms.lease_term_months||24,rent=d.terms.monthly_rent||0;
