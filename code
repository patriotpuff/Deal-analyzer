/* ---- Value-over-time series (12mo/5/10/20yr) ---- */
function valueSeries(d,years){
  const mv=d.property.market_value;if(mv==null)return null;
  const rate=d.appreciation?d.appreciation.annual_rate/100:0.035;
  const sale=(d.facts.last_sale_price&&d.facts.last_sale_year)?{price:d.facts.last_sale_price,year:d.facts.last_sale_year}:null;
  const months=Math.round(years*12);
  const saleMonthsAgo=sale?Math.max(1,(CURRENT_YEAR-sale.year)*12+CURRENT_MONTH-6):null;
  const realizedMonthly=(sale&&saleMonthsAgo)?Math.pow(mv/sale.price,1/saleMonthsAgo)-1:null;
  const anchorMonthly=Math.pow(1+LONG_RUN_ANCHOR/100,1/12)-1;
  const modeledMonthly=Math.pow(1+rate,1/12)-1;
  const pts=[];
  for(let k=months;k>=0;k--){let v;
    if(sale&&saleMonthsAgo!=null&&k<=saleMonthsAgo)v=mv/Math.pow(1+realizedMonthly,k);
    else if(sale&&saleMonthsAgo!=null&&k>saleMonthsAgo)v=sale.price/Math.pow(1+anchorMonthly,k-saleMonthsAgo);
    else v=mv/Math.pow(1+modeledMonthly,k);
    pts.push({k,v});}
  return{pts,sale,saleMonthsAgo,rate};
}
