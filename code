function wireDetail(scope){
  const root=document.getElementById(scope);if(!root)return;
  const main=root.querySelector("#mainPhoto");
  root.querySelectorAll(".thumbs img").forEach(t=>t.onclick=()=>{if(main)main.src=t.src;root.querySelectorAll(".thumbs img").forEach(x=>x.classList.remove("active"));t.classList.add("active");});
  const rb=root.querySelector("#rangeBtns");
  if(rb&&__active){rb.querySelectorAll("button").forEach(b=>b.onclick=()=>{rb.querySelectorAll("button").forEach(x=>x.classList.remove("active"));b.classList.add("active");__series=valueSeries(__active,Number(b.dataset.y));root.querySelector("#valChart").innerHTML=lineChart(__series);});}
  const wrap=root.querySelector("#valChartWrap");
  if(wrap){const tip=wrap.querySelector("#valTip"),guide=wrap.querySelector("#valGuide");
    wrap.addEventListener("mousemove",ev=>{if(!__series)return;const rect=wrap.getBoundingClientRect();const W=rect.width;const vbX=ev.clientX-rect.left;const n=__series.pts.length;let idx=Math.round(((vbX/W*CHART_W)-CHART_PADL)/(CHART_W-CHART_PADL-CHART_PADR)*(n-1));idx=Math.max(0,Math.min(n-1,idx));const p=__series.pts[idx];const px=(CHART_PADL+(CHART_W-CHART_PADL-CHART_PADR)*(idx/(n-1)))/CHART_W*W;guide.style.display="block";guide.style.left=px+"px";tip.style.display="block";tip.style.left=Math.max(0,Math.min(W-130,px+8))+"px";tip.innerHTML=`<b>${money(p.v)}</b> · ${monLabel(p.k)}`;});
    wrap.addEventListener("mouseleave",()=>{tip.style.display="none";guide.style.display="none";});}
  root.querySelectorAll(".comp-row").forEach(r=>r.onclick=()=>openComp(__active,Number(r.dataset.i)));
  if(root.querySelector("#sl_val")&&__active){const run=()=>runSens(root,__active);["sl_val","sl_bb","sl_term","sl_rent"].forEach(idd=>{const el=root.querySelector("#"+idd);if(el)el.oninput=run;});run();}
  const at=root.querySelector("#applyTerms");
  if(at)at.onclick=()=>{const d=DEALS.find(x=>x.id===at.dataset.id)||__active;const g=id=>{const el=root.querySelector("#"+id);const v=el.value;return v===""?null:Number(v);};const sv=id=>{const el=root.querySelector("#"+id);return el?el.value:undefined;};
    const saleIn=g("ed_sale");d.terms.sale_price=saleIn;d.terms._sale_est=(saleIn==null);
    d.terms.loan_balance=g("ed_loan");d.terms._loan_est=(g("ed_loan")==null);
    d.terms.capital_deployed=g("ed_basis");d.terms.buyback_price_y2=g("ed_buyback");d.terms.total_fees=g("ed_fees");d.terms.monthly_rent=g("ed_rent");d.terms.lease_term_months=g("ed_term");
    d.terms.option_fee_mode=sv("ed_optmode");d.terms.option_fee=g("ed_option");d.terms.option_fee_pct=g("ed_optpct");d.terms.option_fee_basis=sv("ed_optbasis");d.terms.cushion_ref=sv("ed_cushref");
    rehydrate(d);__active=d;document.getElementById("modalBody").innerHTML=detailHTML(d);wireDetail("modalBody");renderPipeline();};
  const ss=root.querySelector("#dealStatus");
  if(ss)ss.onchange=()=>{if(__active){__active.status=ss.value;renderOverview();renderPipeline();}};
}
