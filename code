function creditBand(score){if(score==null)return{label:"Unknown",cls:"credit-unknown"};if(score>=740)return{label:score+" · Excellent",cls:"credit-exc"};if(score>=680)return{label:score+" · Good",cls:"credit-good"};if(score>=620)return{label:score+" · Fair",cls:"credit-fair"};return{label:score+" · Poor",cls:"credit-poor"};}
// CIC tri-merge: three bureau scores; the mortgage-representative score is the
// MIDDLE of the three (matches the production credit-client parse_report).
function triMerge(base,rnd){
  const lo=clamp(Math.round(base-(5+rnd()*16)),300,850);
  const hi=clamp(Math.round(base+(5+rnd()*16)),300,850);
  const vals=[lo,base,hi],off=Math.floor(rnd()*3),rot=i=>vals[(i+off)%3];
  return{equifax:rot(0),experian:rot(1),transunion:rot(2),mid:base};
}
function genBorrower(d){
  const rnd=seededRand("borrower"+d.client);const real=REAL_BORROWER[d.client]||{};
  const score=real.creditScore!=null?real.creditScore:(580+Math.floor(rnd()*180));
  const income=real.monthlyIncome!=null?real.monthlyIncome:(3000+Math.floor(rnd()*7000));
  const housingTarget=d.terms&&d.terms.monthly_rent?d.terms.monthly_rent:Math.round((d.property.market_value||140000)*0.006);
  const dti=Math.round((housingTarget/income)*100);
  const effScore=real.creditScore!=null?real.creditScore:score;
  const hasReal=Object.keys(real).length>0;
  const repScore=real.creditScore!=null?real.creditScore:(real.creditNote?null:score);
  const bureaus=repScore!=null?triMerge(repScore,rnd):null;
  return{
    creditScore:repScore,           // representative = middle of the tri-merge
    bureaus,                         // {equifax, experian, transunion, mid}
    creditNote:real.creditNote||null,
    monthlyIncome:real.monthlyIncome!=null?real.monthlyIncome:income,
    employment:real.employment||"Not provided",
    estimatedDTI:dti,
    reserves:real.reserves||"Not provided",
    intent:real.intent||"Not stated",
    bankruptcy:rnd()>0.85,
    // Credit-report detail (provider upload).
    utilizationPct:Math.round(10+rnd()*70),
    openTradelines:3+Math.floor(rnd()*12),
