function renderPipeline(){renderSummary();const f=document.getElementById("filterRec").value;let rows=DEALS.filter(d=>!f||d.analysis.recommendation===f);
  if(__sortKey){rows=rows.slice().sort((x,y)=>{const a=sortVal(x,__sortKey),b=sortVal(y,__sortKey);if(a<b)return -1*__sortDir;if(a>b)return 1*__sortDir;return 0;});}
  document.getElementById("count").textContent=`${rows.length} of ${DEALS.length} shown`;
  renderMap(rows);
